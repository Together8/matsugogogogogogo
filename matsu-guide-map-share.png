<defs><style>
.t{font:800 42px sans-serif;fill:#23677e}.s{font:600 19px sans-serif;fill:#5e7f8b}.l{font:700 17px sans-serif;fill:#24424d}.sm{font:600 14px sans-serif;fill:#6f8892}.n{font:800 14px sans-serif;fill:white}
